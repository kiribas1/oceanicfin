---

<section class="quiz-section" id="banking-quiz">
  <div class="quiz-container">
    <h2 class="quiz-title">{l.title}</h2>
    <div class="quiz-header">
      <span class="quiz-progress" id="quiz-progress">{l.question} 1 {l.of} 12</span>
      <span class="quiz-score" id="quiz-score">{l.score}: 0/0</span>
    </div>
    <div class="quiz-question" id="quiz-question"></div>
    <div class="quiz-options" id="quiz-options"></div>
    <div class="quiz-feedback" id="quiz-feedback"></div>
    <button class="quiz-btn" id="quiz-next" style="display:none">{l.next}</button>
    <button class="quiz-btn quiz-btn-replay" id="quiz-replay" style="display:none">{l.playAgain}</button>
  </div>
</section>

<script define:vars={{ questions, lang, labels }}>
  const l = labels[lang] || labels.en;
  const allQ = questions.map((q, i) => ({ ...q, idx: i }));

  // Shuffle and pick 12
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const gameQuestions = shuffle(allQ).slice(0, 12);
  let current = 0;
  let score = 0;

  function renderQuestion() {
    const q = gameQuestions[current];
    const qEl = document.getElementById('quiz-question');
    const oEl = document.getElementById('quiz-options');
    const fEl = document.getElementById('quiz-feedback');
    const nEl = document.getElementById('quiz-next');
    const pEl = document.getElementById('quiz-progress');
    const rEl = document.getElementById('quiz-replay');

    pEl.textContent = `${l.question} ${current + 1} ${l.of} 12`;
    qEl.textContent = q.q[lang] || q.q.en;
    fEl.textContent = '';
    fEl.className = 'quiz-feedback';
    nEl.style.display = 'none';
    rEl.style.display = 'none';

    const opts = shuffle(q.options[lang] || q.options.en);
    oEl.innerHTML = '';
    opts.forEach(opt => {
      const btn = document.createElement('button');
      btn.className = 'quiz-option';
      btn.textContent = opt;
      btn.addEventListener('click', () => handleAnswer(opt, q));
      oEl.appendChild(btn);
    });
  }

  function handleAnswer(selected, q) {
    const correct = (q.a[lang] || q.a.en);
    const isCorrect = selected === correct;
    const fEl = document.getElementById('quiz-feedback');
    const oEl = document.getElementById('quiz-options');
    const nEl = document.getElementById('quiz-next');
    const sEl = document.getElementById('quiz-score');

    // Disable all buttons
    oEl.querySelectorAll('.quiz-option').forEach(btn => {
      btn.disabled = true;
      if (btn.textContent === correct) btn.classList.add('correct');
      if (btn.textContent === selected && !isCorrect) btn.classList.add('wrong');
    });

    if (isCorrect) {
      score++;
      fEl.innerHTML = `<strong>${l.correct}</strong> ${l.funFact}: ${q.fact[lang] || q.fact.en}`;
      fEl.className = 'quiz-feedback show correct';
    } else {
      fEl.innerHTML = `<strong>${l.wrong}</strong> ${l.answer}: ${correct}. ${l.funFact}: ${q.fact[lang] || q.fact.en}`;
      fEl.className = 'quiz-feedback show wrong';
    }

    sEl.textContent = `${l.score}: ${score}/${current + 1}`;

    if (current < 11) {
      nEl.style.display = 'inline-block';
    } else {
      const rEl = document.getElementById('quiz-replay');
      rEl.style.display = 'inline-block';
    }
  }

  document.getElementById('quiz-next').addEventListener('click', () => {
    current++;
    renderQuestion();
  });

  document.getElementById('quiz-replay').addEventListener('click', () => {
    window.location.reload();
  });

  renderQuestion();
</script>

<style>
  .quiz-section {
    max-width: 1100px;
    margin: 40px auto;
    padding: 0 20px;
  }
  .quiz-container {
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(14, 165, 233, 0.15);
    border-radius: 16px;
    padding: 36px;
  }
  .quiz-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: #f1f5f9;
