---
interface Props {
  title: string;
  description: string;
  lang: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, lang, canonicalUrl, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const locales = ['en', 'es', 'zh', 'ru', 'pt', 'ar'];
const langNames: Record<string, string> = {
  en: 'English',
  es: 'Español',
  zh: '中文',
  ru: 'Русский',
  pt: 'Português',
  ar: 'العربية',
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Hreflang -->
    {locales.map((loc) => {
      const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
      return <link rel="alternate" hreflang={loc} href={`${siteUrl}${path}`} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2701690512336282"
      crossorigin="anonymous"
    ></script>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: #e2e8f0;
        background: #060810;
      }
      a {
        color: #0ea5e9;
        text-decoration: none;
      }
      a:hover {
        color: #38bdf8;
        text-decoration: none;
      }
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
      }

      /* Header */
      header {
        background: rgba(6, 8, 16, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(14, 165, 233, 0.15);
        color: white;
        padding: 16px 0;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }
      .logo {
        font-size: 1.4rem;
        font-weight: 800;
        color: white;
        letter-spacing: -0.02em;
      }
      .logo:hover {
        text-decoration: none;
        color: #0ea5e9;
      }
      nav {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }
      nav a {
        color: #94a3b8;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.2s;
      }
      nav a:hover,
      nav a.active {
        color: #0ea5e9;
        background: rgba(14, 165, 233, 0.1);
        text-decoration: none;
      }

      /* Main */
      main {
        min-height: 70vh;
        padding: 0;
      }

      /* Footer */
      footer {
        background: rgba(6, 8, 16, 0.95);
        border-top: 1px solid rgba(14, 165, 233, 0.1);
        color: #64748b;
        padding: 32px 0;
        text-align: center;
        font-size: 0.85rem;
      }
      footer a {
        color: #0ea5e9;
      }

      /* Hero */
      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 80px 20px 60px;
        overflow: hidden;
        background: #060810;
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 60% at 50% 40%, rgba(14, 165, 233, 0.15) 0%, transparent 70%),
          radial-gradient(ellipse 60% 50% at 30% 60%, rgba(3, 105, 161, 0.12) 0%, transparent 60%),
          radial-gradient(ellipse 50% 40% at 70% 50%, rgba(20, 184, 166, 0.08) 0%, transparent 60%);
        animation: heroGlow 8s ease-in-out infinite alternate;
      }
      @keyframes heroGlow {
        0% { opacity: 0.7; transform: scale(1); }
        100% { opacity: 1; transform: scale(1.05); }
      }
      .hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(14, 165, 233, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(14, 165, 233, 0.05) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 70%);
        -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 70%);
        animation: gridWave 12s ease-in-out infinite alternate;
      }
      @keyframes gridWave {
        0% { transform: perspective(500px) rotateX(2deg) translateY(0); }
        100% { transform: perspective(500px) rotateX(-2deg) translateY(-10px); }
      }
      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 800px;
      }
      .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(14, 165, 233, 0.1);
        border: 1px solid rgba(14, 165, 233, 0.3);
        border-radius: 999px;
        padding: 6px 18px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #0ea5e9;
        margin-bottom: 28px;
      }
      .hero-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #0ea5e9;
        animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(14, 165, 233, 0.4); }
        50% { opacity: 0.7; box-shadow: 0 0 0 8px rgba(14, 165, 233, 0); }
      }
      .hero h1 {
        font-size: 3.5rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 8px;
        color: white;
        letter-spacing: -0.03em;
      }
      .hero-gradient-text {
        font-size: 3rem;
        font-weight: 800;
        background: linear-gradient(135deg, #0ea5e9, #0369a1, #14b8a6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 24px;
        line-height: 1.2;
      }
      .hero-lead {
        font-size: 1.15rem;
        color: #94a3b8;
        max-width: 600px;
        margin: 0 auto 40px;
        line-height: 1.7;
      }
      .hero-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
      }
      .hero-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }
      .hero-stat-icon {
        font-size: 1.5rem;
        margin-bottom: 4px;
      }
      .hero-stat-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #e2e8f0;
      }
      .hero-stat-sub {
        font-size: 0.75rem;
        color: #64748b;
      }

      /* Cards */
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        margin: 32px 0;
        padding: 0 20px;
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
      }
      .card {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(14, 165, 233, 0.1);
        border-radius: 12px;
        padding: 28px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }
      .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #0ea5e9, #14b8a6);
        opacity: 0;
        transition: opacity 0.3s;
      }
      .card:hover {
        transform: translateY(-4px);
        border-color: rgba(14, 165, 233, 0.3);
        box-shadow: 0 8px 32px rgba(14, 165, 233, 0.1);
      }
      .card:hover::before {
        opacity: 1;
      }
      .card-icon {
        font-size: 2rem;
        margin-bottom: 12px;
        display: block;
      }
      .card h2 {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 10px;
        color: #f1f5f9;
        letter-spacing: -0.01em;
      }
      .card p {
        color: #94a3b8;
        font-size: 0.92rem;
        line-height: 1.6;
      }

      /* Ad slots */
      .ad-slot {
        background: rgba(15, 23, 42, 0.4);
        border: 1px dashed rgba(14, 165, 233, 0.15);
        padding: 20px;
        text-align: center;
        margin: 32px auto;
        max-width: 1100px;
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #475569;
        font-size: 0.8rem;
        border-radius: 8px;
      }

      /* Section wrapper for content below hero */
      .content-section {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
      }

      @media (max-width: 640px) {
        .hero h1 {
          font-size: 2rem;
        }
        .hero-gradient-text {
          font-size: 1.6rem;
        }
        .hero-lead {
          font-size: 1rem;
        }
        .hero-stats {
          gap: 24px;
        }
        .card-grid {
          grid-template-columns: 1fr;
          padding: 0 16px;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <a class="logo" href={`/${lang}/`}><slot name="logo">OceanicFin</slot></a>
        <nav>
          {locales.map((loc) => {
            const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
            return (
              <a href={path} class={loc === lang ? 'active' : ''}>
                {langNames[loc]}
              </a>
            );
          })}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container">
        <p>&copy; {new Date().getFullYear()} <slot name="footer-name">OceanicFin</slot>. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
