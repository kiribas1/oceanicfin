---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BankingQuiz from '../../components/BankingQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="OceanicFin - AI驱动的离岸银行与金融科技平台"
  description="由人工智能驱动的新一代离岸银行平台。多币种账户、AI合规管理、跨境支付和蓝色经济投资。"
  lang="zh"
>
  <Fragment slot="logo">OceanicFin</Fragment>
  <Fragment slot="footer-name">OceanicFin</Fragment>

  <section class="hero">
    <div class="hero-content">
      <div class="hero-pill">
        <span class="hero-pill-dot"></span>
        AI驱动的离岸银行
      </div>
      <h1>OceanicFin</h1>
      <div class="hero-gradient-text">智能银行 &middot; 全球覆盖</div>
      <p class="hero-lead">由人工智能驱动的新一代离岸银行平台。多币种账户、AI驱动的合规管理和无缝跨境支付。</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-icon">🤖</span>
          <span class="hero-stat-label">AI驱动</span>
          <span class="hero-stat-sub">智能分析</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-icon">💱</span>
          <span class="hero-stat-label">多币种</span>
          <span class="hero-stat-sub">50+种货币</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-icon">🌐</span>
          <span class="hero-stat-label">全球访问</span>
          <span class="hero-stat-sub">全球覆盖</span>
        </div>
      </div>
    </div>
  </section>

  <div class="ad-slot">广告位 - Google AdSense</div>

  <BankingQuiz lang="zh" />

  <div class="card-grid">
    <article class="card">
      <span class="card-icon">🏦</span>
      <h2>离岸银行</h2>
      <p>在顶级离岸司法管辖区提供多币种支持的国际账户。为寻求资产多元化的全球公民和企业量身打造的隐私优先银行解决方案。</p>
    </article>
    <article class="card">
      <span class="card-icon">🤖</span>
      <h2>AI金融服务</h2>
      <p>机器学习欺诈检测、自动化合规监控和智能投资组合分析。利用人工智能优化您的金融运营和风险管理。</p>
    </article>
    <article class="card">
      <span class="card-icon">💳</span>
      <h2>数字支付</h2>
      <p>通过SWIFT和SEPA网络的无缝跨境转账、加密货币-法币桥接和即时结算技术。以最低费用和最快速度在全球范围内转移资金。</p>
    </article>
    <article class="card">
      <span class="card-icon">🌊</span>
      <h2>蓝色经济投资</h2>
      <p>海洋债券、海事投资基金、可持续海洋投资组合和符合ESG标准的蓝色经济机遇。投资于海洋产业和保护事业的未来。</p>
    </article>
    <article class="card">
      <span class="card-icon">🔐</span>
      <h2>安全与合规</h2>
      <p>自动化KYC/AML筛查、监管沙箱参与和多司法管辖区合规框架。通过AI驱动的解决方案领先应对不断变化的全球金融法规。</p>
    </article>
    <article class="card">
      <span class="card-icon">🌍</span>
      <h2>全球市场准入</h2>
      <p>代理银行网络、新兴市场准入、金砖国家一体化路径和贸易融资解决方案。进入成熟和发展中的金融市场机遇。</p>
    </article>
  </div>

  <div class="ad-slot">广告位 - Google AdSense</div>

  <WeeklyNews lang="zh" />
</BaseLayout>
